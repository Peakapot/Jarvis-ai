{
  "$comment": "Intelligence Product Registry — the single source of truth for all Jarvis daily intelligence briefs. NEW intelligence products are added by appending an entry here (and supplying the referenced workflow/prompt/template/sources). Nothing in the platform hardcodes a fixed list of products: install.sh, healthcheck.sh, status.sh and backup.sh all iterate this registry, so future products (Defence, AI, Government, Healthcare, Market intelligence, ...) follow exactly the same architecture. Reuses the established configuration framework (Configuration over hard coding).",
  "schemaVersion": 1,
  "products": [
    {
      "id": "cyber-brief",
      "name": "Daily Cyber Threat Intelligence Brief",
      "module": "core",
      "status": "active",
      "enabledEnv": "CYBER_BRIEF_ENABLED",
      "enabledDefault": "true",
      "scheduleEnv": "CYBER_BRIEF_SCHEDULE_CRON",
      "scheduleDefault": "0 6 * * *",
      "workflow": "workflows/core/cyber-brief.json",
      "prompt": "cyber-brief.analyst",
      "sourcesFile": "config/rss-feeds.txt",
      "reportDir": "reports/cyber-brief",
      "archiveDir": "reports/archive/cyber-brief",
      "template": "templates/report/cyber-brief.html.tpl",
      "outputs": ["html", "pdf", "email", "archive"],
      "coverImage": true,
      "telegramCommand": "/cyber"
    },
    {
