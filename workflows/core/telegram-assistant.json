    {
      "id": "handler-ai",
      "name": "AI Assistant (provider-abstracted)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1040,
        420
      ],
      "parameters": {
        "method": "POST",
        "url": "={{ $env.OLLAMA_BASE_URL || 'http://jarvis-ollama:11434' }}/api/chat",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.OLLAMA_DEFAULT_MODEL || 'llama3.1:8b' }}\",\n  \"stream\": false,\n  \"messages\": [{\"role\":\"user\",\"content\": {{ JSON.stringify($json.message.text) }} }]\n}",
        "options": {
          "timeout": 60000
        }
      },
      "onError": "continueErrorOutput",
      "notes": "Default provider is Ollama. Switching AI_PROVIDER points this at the resolved endpoint (AI Provider Abstraction)."
    },
    {
      "id": "handler-intel",
      "name": "Latest Intelligence Brief",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        240
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "// Serve intelligence products to Telegram: latest edition, recent history,\n// or an organisation/date search. Registry-agnostic: the command maps to a\n// product archive directory under /reports/archive/<id> (mounted). Reading the\n// directory requires the n8n env NODE_FUNCTION_ALLOW_BUILTIN=fs (set in\n// docker-compose). Fails safe: if listing is unavailable, returns guidance.\nconst text = ($('Telegram Trigger').item.json.message.text || '').trim();\nconst cmd = text.split(/\\s+/)[0].toLowerCase();\nconst query = text.split(/\\s+/).slice(1).join(' ').toLowerCase();\nconst map = {\n  '/opportunities': { id: 'cyber-opportunities', name: 'Cyber Opportunities Brief' },\n  '/energy': { id: 'energy-intelligence', name: 'Energy Intelligence Brief' },\n  '/cyber': { id: 'cyber-brief', name: 'Cyber Threat Brief' },\n  '/defence': { id: 'defence-cyber', name: 'Cyber Defence Watch' }\n};\nconst p = map[cmd] || map['/opportunities'];\nlet reply;\ntry {\n  const fs = require('fs');\n  const dir = `/reports/archive/${p.id}`;\n  let files = fs.readdirSync(dir).filter(f => f.endsWith('.html')).sort();\n  if (query) files = files.filter(f => f.toLowerCase().includes(query));\n  if (!files.length) {\n    reply = `No ${p.name} editions found${query ? ` matching \\\"${query}\\\"` : ''} yet. Briefings are generated on schedule and emailed automatically.`;\n  } else {\n    const latest = files[files.length - 1];\n    const recent = files.slice(-5).reverse().map(f => ` • ${f}`).join('\\n');\n    reply = `📰 ${p.name}\\nLatest: ${latest}\\nRecent editions:\\n${recent}\\n\\nStored under reports/archive/${p.id}/. Reply with an org or date to search (e.g. \\\"${cmd} adnoc\\\").`;\n  }\n} catch (e) {\n  reply = `📰 ${p.name}: the latest edition is delivered by email and stored under reports/archive/${p.id}/. (Live listing unavailable: ${e.message})`;\n}\nreturn [{ json: { reply } }];"
      },
      "onError": "continueErrorOutput",
      "notes": "Handles /opportunities and /energy (and /cyber). Latest edition, history, or org/date search. Failure path -> Failure Notice."
    },
    {
      "id": "send-reply",
      "name": "Send Telegram Reply",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1360,
        240
      ],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "={{ $json.reply || $json.message?.content || 'Done.' }}"
      },
      "onError": "continueErrorOutput"
    },
    {
      "id": "fail-notice",
      "name": "Failure Notice",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1360,
        480
      ],
      "parameters": {
        "resource": "message",
        "operation": "sendMessage",
        "chatId": "={{ $('Telegram Trigger').item.json.message.chat.id }}",
        "text": "⚠️ Jarvis hit an error handling that request. The team has been notified and it has been logged."
      },
      "notes": "Failure path: AI/Ollama unavailable -> tell the user gracefully (Error Handling)."
