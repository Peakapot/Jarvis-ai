  "name": "Jarvis · Telegram Assistant",
  "meta": {
    "jarvisModule": "telegram-assistant",
    "jarvisVersion": "1.0.0",
    "description": "Primary interface. Receives Telegram messages, authorises the chat, routes commands (/help /status /research /emails /image /cyber) and replies. New commands are added by extending the Command Router switch — easy to add (Telegram Assistant Requirements). Every external call has a failure path (Error Handling).",
    "prompts": [
      "telegram.router",
      "system.jarvis-core"
    ],
    "envVars": [
      "TELEGRAM_BOT_TOKEN",
      "TELEGRAM_ALLOWED_CHAT_IDS"
    ]
  },
  "settings": {
    "executionOrder": "v1",
    "saveDataErrorExecution": "all",
    "saveExecutionProgress": true,
    "errorWorkflow": "Jarvis · Error Handler"
  },
