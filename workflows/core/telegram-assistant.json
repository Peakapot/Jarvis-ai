        300
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "combinator": "and",
          "conditions": [
            {
              "leftValue": "={{ $env.TELEGRAM_ALLOWED_CHAT_IDS }}",
              "rightValue": "={{ String($json.message.chat.id) }}",
              "operator": {
                "type": "string",
                "operation": "contains"
              }
            }
          ]
        }
      },
      "notes": "Access control: only chat IDs in TELEGRAM_ALLOWED_CHAT_IDS proceed."
    },
