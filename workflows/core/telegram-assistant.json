    {
      "id": "tk-prep",
      "name": "Prep Toolkit Cmd",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        620
      ],
      "parameters": {
        "language": "javaScript",
        "jsCode": "const m=$json.message||{}; let txt=(m.text||'').toString(); let cmd=(txt.split(/\\s+/)[0]||'').toLowerCase(); if(cmd==='/explainer') cmd='/poster'; return [{ json:{ cmd:cmd, text:txt, chatId:(m.chat&&m.chat.id)||'' } }];"
      }
    },
