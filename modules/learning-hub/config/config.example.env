# =============================================================================
# learning-hub — module configuration example
# -----------------------------------------------------------------------------
# These keys are consumed from the root .env (the installer seeds them from
# .env.example). Listed here for documentation/self-containment. No secrets.
# =============================================================================

# Enable/disable the scheduled publication run (fail-safe toggle).
LEARNING_HUB_ENABLED=true

# Schedule — default 07:00 on the 1st of each month. Any cron expression.
LEARNING_HUB_SCHEDULE_CRON=0 7 1 * *

# Knowledge-check pass mark (%) for the derived e-learning course.
LEARNING_HUB_PASS_MARK=80

# Magazine output formats and the awareness source list.
LEARNING_HUB_OUTPUT_FORMATS=pdf,html,archive
LEARNING_HUB_SOURCES_FILE=config/learning-hub-sources.txt

# Host port for the local Learning Dashboard (nginx static service).
DASHBOARD_PORT=8088

# Cover image uses the shared Image Provider Abstraction (IMAGE_PROVIDER) and the
# root IMAGE_* / OPENAI_* settings; section images reuse ELEARNING_SECTION_IMAGES.
# AI content uses the shared AI_PROVIDER (ollama / claude / openai). Nothing
# module-specific or secret is required here.
