# =============================================================================
# dealforge-assistant module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. NEVER put secret VALUES
# here. CRM credentials are configured in n8n, not in this repo.
# =============================================================================

# Enable this module's workflow (true|false).
DEALFORGE_ASSISTANT_ENABLED=false

# Optional CRM backend (none|hubspot|pipedrive).
DEALFORGE_CRM_PROVIDER=none

# Comma-separated pipeline stage names used for stage notes.
DEALFORGE_PIPELINE_STAGES=lead,qualified,proposal,negotiation,won,lost

# LLM steps route through the core AI Provider Abstraction (AI_PROVIDER /
# OLLAMA_*). Do NOT hardcode provider specifics in this module.
