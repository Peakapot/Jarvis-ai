# =============================================================================
# image-assistant module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. NEVER put secret VALUES
# here — reference env var NAMES only. Secrets live in .env (git-ignored).
# =============================================================================

# Enable this module's workflow (true|false).
IMAGE_ASSISTANT_ENABLED=false

# Image Provider Abstraction: selects config/providers/image/<IMAGE_PROVIDER>.json
IMAGE_PROVIDER=openai
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024

# Secret: set the VALUE only in .env. The openai image descriptor reads
# OPENAI_IMAGE_API_KEY and falls back to OPENAI_API_KEY.
# OPENAI_IMAGE_API_KEY=

# The text refinement step routes through the core AI Provider Abstraction
# (AI_PROVIDER / OLLAMA_*). Image generation routes through the image provider
# descriptor above. Do NOT hardcode provider specifics in this module.
