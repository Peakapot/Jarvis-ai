# =============================================================================
# cyber-opportunities — module configuration example
# -----------------------------------------------------------------------------
# These keys are consumed from the root .env (the installer seeds them from
# .env.example). Listed here for documentation/self-containment. No secrets.
# =============================================================================

# Enable/disable this intelligence product (fail-safe toggle).
CYBER_OPPS_ENABLED=true

# Schedule — default 06:15 daily. Any cron expression.
CYBER_OPPS_SCHEDULE_CRON=15 6 * * *

# Focus regions (GCC primary; UK/Europe/Global secondary).
CYBER_OPPS_PRIMARY_REGIONS=UAE,Saudi Arabia,Qatar,Oman,Bahrain,Kuwait
CYBER_OPPS_SECONDARY_REGIONS=United Kingdom,Europe,Global

# Output formats and source list.
CYBER_OPPS_OUTPUT_FORMATS=html,pdf,email,archive
CYBER_OPPS_SOURCES_FILE=config/cyber-opportunities-sources.txt

# Cover image uses the shared Image Provider Abstraction (IMAGE_PROVIDER) and
# the root IMAGE_* / OPENAI_* settings — nothing module-specific is required.
