# =============================================================================
# knowledge-assistant module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. NEVER put secret VALUES
# here — reference env var NAMES only. Secrets live in .env (git-ignored).
# =============================================================================

# Enable this module's workflows (true|false).
KNOWLEDGE_ASSISTANT_ENABLED=false

# Future Qdrant vector DB (core service). Used for embeddings storage / memory.
QDRANT_URL=http://jarvis-qdrant:6333
KNOWLEDGE_COLLECTION=jarvis_knowledge
KNOWLEDGE_TOP_K=5

# Secret: set the VALUE only in .env, never in the repo. Leave blank if Qdrant
# does not require authentication.
# QDRANT_API_KEY=

# Embeddings/chat route through the core AI Provider Abstraction (AI_PROVIDER /
# OLLAMA_*). Do NOT hardcode provider specifics in this module.
