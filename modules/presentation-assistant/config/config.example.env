# =============================================================================
# presentation-assistant module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. NEVER put secret VALUES
# here — reference env var NAMES only.
# =============================================================================

# Enable this module's workflow (true|false).
PRESENTATION_ASSISTANT_ENABLED=false

# Default target number of slides when the brief does not specify one.
PRESENTATION_DEFAULT_SLIDES=10

# LLM steps route through the core AI Provider Abstraction (AI_PROVIDER /
# OLLAMA_*). Do NOT hardcode provider specifics in this module.
