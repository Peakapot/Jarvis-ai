# =============================================================================
# meeting-assistant module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. NEVER put secret VALUES
# here — reference env var NAMES only.
# =============================================================================

# Enable this module's workflow (true|false).
MEETING_ASSISTANT_ENABLED=false

# Default output format for summaries (markdown|json).
MEETING_OUTPUT_FORMAT=markdown

# Summarisation routes through the core AI Provider Abstraction (AI_PROVIDER /
# OLLAMA_*). Do NOT hardcode provider specifics in this module.
