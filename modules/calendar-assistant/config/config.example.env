# =============================================================================
# calendar-assistant module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. NEVER put secret VALUES
# here. Calendar OAuth credentials are configured in n8n, not in this repo.
# =============================================================================

# Enable this module's workflows (true|false).
CALENDAR_ASSISTANT_ENABLED=false

# Calendar backend (google|microsoft365|caldav).
CALENDAR_PROVIDER=google

# Default IANA timezone for event drafts and agendas.
CALENDAR_DEFAULT_TZ=Europe/London

# Target calendar id for queries and drafts.
CALENDAR_ID=primary

# LLM steps route through the core AI Provider Abstraction (AI_PROVIDER /
# OLLAMA_*). Do NOT hardcode provider specifics in this module.
