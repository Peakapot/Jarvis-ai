# =============================================================================
# energy-intelligence — module configuration example
# -----------------------------------------------------------------------------
# These keys are consumed from the root .env (seeded by the installer from
# .env.example). Listed here for documentation/self-containment. No secrets.
# =============================================================================

# Enable/disable this intelligence product (fail-safe toggle).
ENERGY_BRIEF_ENABLED=true

# Schedule — default 06:30 daily (configurable). Any cron expression.
ENERGY_BRIEF_SCHEDULE_CRON=30 6 * * *

# Focus entities.
ENERGY_BRIEF_PRIMARY_FOCUS=ADNOC,ADNOC Gas,ADNOC Drilling,TAQA,Masdar,Borouge,TA'ZIZ,Mubadala Energy,UAE Energy Sector
ENERGY_BRIEF_SECONDARY_FOCUS=Saudi Aramco,Shell,BP,Chevron,ExxonMobil,TotalEnergies,QatarEnergy

# Output formats and source list.
ENERGY_BRIEF_OUTPUT_FORMATS=html,pdf,email,archive
ENERGY_BRIEF_SOURCES_FILE=config/energy-sources.txt

# Cover image uses the shared Image Provider Abstraction (IMAGE_PROVIDER) and
# the root IMAGE_* / OPENAI_* settings — nothing module-specific is required.
