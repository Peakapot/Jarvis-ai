# =============================================================================
# _template module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. These are placeholders
# for a copy-me template. NEVER put secrets here — reference env var NAMES only
# and store actual secret VALUES in .env (which is git-ignored).
# =============================================================================

# Enable this module's workflow (true|false).
TEMPLATE_FEATURE_ENABLED=false

# AI provider is inherited from core (AI_PROVIDER / OLLAMA_* etc.).
# Modules should NOT hardcode provider specifics — reuse the core abstraction.
