# =============================================================================
# mindhaven-assistant module configuration (example)
# -----------------------------------------------------------------------------
# Copy the relevant lines into the repository root .env. NEVER put secret VALUES
# here — reference env var NAMES only.
# =============================================================================

# Enable this module's workflow (true|false).
MINDHAVEN_ASSISTANT_ENABLED=false

# Region-appropriate crisis resources, surfaced when crisis indicators appear.
# REPLACE with the correct resources for your country/region.
MINDHAVEN_CRISIS_RESOURCES="If you are in immediate danger call your local emergency number. UK: Samaritans 116 123. US: 988. Or contact a local crisis line."

# LLM steps route through the core AI Provider Abstraction (AI_PROVIDER /
# OLLAMA_*). The local-first Ollama default keeps journal content on the host.
# Do NOT hardcode provider specifics in this module.
