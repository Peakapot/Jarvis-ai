# =============================================================================
# .env.example — Jarvis configuration template (Configuration over hard coding)
# -----------------------------------------------------------------------------
# Copy to .env (install.sh does this automatically) and fill in the values.
#
#   cp .env.example .env
#
# SECURITY: .env is git-ignored and must NEVER be committed. It holds all
# secrets. This repository is PUBLIC — no real credentials belong in any
# tracked file. The installer generates secrets locally where it can.
# =============================================================================

# ----------------------------------------------------------------------------
# Core / platform
# ----------------------------------------------------------------------------
TZ=UTC
JARVIS_DOCKER_NETWORK=jarvis-net
JARVIS_LOG_LEVEL=info                 # debug | info | warn | error

# Validation thresholds (override to match your host).
JARVIS_MIN_RAM_GB=8
JARVIS_MIN_CPU_CORES=2
JARVIS_MIN_DISK_GB=20

# Backup retention (number of full backups to keep).
JARVIS_BACKUP_KEEP=14

# ----------------------------------------------------------------------------
# n8n
# ----------------------------------------------------------------------------
N8N_IMAGE=docker.n8n.io/n8nio/n8n:latest
N8N_CONTAINER_NAME=jarvis-n8n
N8N_SERVICE_NAME=n8n
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASE_URL=http://localhost:5678
N8N_LOG_LEVEL=info
N8N_SECURE_COOKIE=false
N8N_DATA_VOLUME=jarvis_n8n_data
# Generated locally by install.sh — leave blank to auto-generate.
N8N_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# AI Provider Abstraction — Ollama is the DEFAULT provider.
# Switching providers is a configuration change, not a code change.
#   AI_PROVIDER: ollama | claude | openai
# ----------------------------------------------------------------------------
AI_PROVIDER=ollama

# Ollama (default, local-first)
OLLAMA_IMAGE=ollama/ollama:latest
OLLAMA_CONTAINER_NAME=jarvis-ollama
OLLAMA_SERVICE_NAME=ollama
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DATA_VOLUME=jarvis_ollama_data
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_KEEP_ALIVE=5m

# Claude (optional alternative provider)
# ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_BASE_URL=https://api.anthropic.com

# OpenAI (optional alternative provider)
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# ----------------------------------------------------------------------------
# Image Provider Abstraction
#   IMAGE_PROVIDER: openai | (future providers)
# ----------------------------------------------------------------------------
IMAGE_PROVIDER=openai
# OPENAI_IMAGE_API_KEY=          # falls back to OPENAI_API_KEY if unset
IMAGE_MODEL=gpt-image-1
IMAGE_SIZE=1024x1024

# ----------------------------------------------------------------------------
# Email Provider Abstraction
#   EMAIL_PROVIDER: gmail | microsoft365 | smtp
# Switching providers must not require workflow redesign.
# ----------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM=
EMAIL_TO=

# SMTP (generic)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls               # tls | ssl | none
# SMTP_USER=
# SMTP_PASSWORD=

# Gmail / Microsoft 365 use OAuth credentials configured inside n8n;
# only the provider selection and From/To live here.

# ----------------------------------------------------------------------------
# Telegram Assistant (primary interface)
# ----------------------------------------------------------------------------
# TELEGRAM_BOT_TOKEN=
# Comma-separated list of authorised chat IDs (access control).
TELEGRAM_ALLOWED_CHAT_IDS=
# Chat that scheduled briefs (Energy / Cyber) are delivered to as PDFs.
# Leave blank to use the first entry in TELEGRAM_ALLOWED_CHAT_IDS.
TELEGRAM_BRIEF_CHAT_ID=

# ----------------------------------------------------------------------------
# Intelligence Products (professional intelligence products)
# All products are registered in config/intelligence/products.json. New products
# follow the same pattern — no code change required (Future expansion).
# ----------------------------------------------------------------------------

# --- Awareness Toolkit ---
# Blank = generic branding. Set a client name to white-label generated assets.
CLIENT_NAME=
# Topic used when an awareness tool is run with no topic (blank form / bare command).
DEFAULT_AWARENESS_TOPIC=phishing

# --- Cyber Brief (Weekly Cyber Threat Intelligence Magazine) ---
CYBER_BRIEF_ENABLED=true
CYBER_BRIEF_SCHEDULE_CRON="0 7 * * 1"      # weekly, Monday 07:00 (local TZ)
CYBER_BRIEF_REGION_FOCUS=UAE
# Generate an AI hero image per section (extra image credits per issue). false = off.
CYBER_SECTION_IMAGES=true
CYBER_BRIEF_OUTPUT_FORMATS=html,pdf,email,archive

# --- Cyber Opportunities Brief (Deliverable 13) ---
CYBER_OPPS_ENABLED=true
CYBER_OPPS_SCHEDULE_CRON="15 6 * * *"      # daily 06:15 (configurable)
CYBER_OPPS_PRIMARY_REGIONS="UAE,Saudi Arabia,Qatar,Oman,Bahrain,Kuwait"
CYBER_OPPS_SECONDARY_REGIONS="United Kingdom,Europe,Global"
CYBER_OPPS_OUTPUT_FORMATS=html,pdf,email,archive

# --- Energy Intelligence Brief (Deliverable 14) ---
ENERGY_BRIEF_ENABLED=true
ENERGY_BRIEF_SCHEDULE_CRON="30 6 * * *"    # daily 06:30 (configurable)
ENERGY_BRIEF_PRIMARY_FOCUS="ADNOC,ADNOC Gas,ADNOC Drilling,TAQA,Masdar,Borouge,TA'ZIZ,Mubadala Energy,UAE Energy Sector"
ENERGY_BRIEF_SECONDARY_FOCUS="Saudi Aramco,Shell,BP,Chevron,ExxonMobil,TotalEnergies,QatarEnergy"
ENERGY_BRIEF_OUTPUT_FORMATS=html,pdf,email,archive

# --- Cyber Defence Watch (weekly OSINT cyber-defence brief for KSA MOD) ---
DEFENCE_BRIEF_ENABLED=true
DEFENCE_BRIEF_SCHEDULE_CRON="30 5 * * 1"   # weekly, Monday 05:30 (staggered)
# AI hero image per section (extra image credits). Set true for the final publish.
DEFENCE_SECTION_IMAGES=false
DEFENCE_BRIEF_OUTPUT_FORMATS=html,pdf,telegram,archive

# ----------------------------------------------------------------------------
# Future services (enabled via Compose profiles; see docker-compose.yml)
# ----------------------------------------------------------------------------
QDRANT_IMAGE=qdrant/qdrant:latest
QDRANT_PORT=6333
QDRANT_DATA_VOLUME=jarvis_qdrant_data

PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
# GRAFANA_ADMIN_PASSWORD=
